# Sephirot itself does not require an LLM key for local spec scoring/building.
# Agent shells such as Claude Code, Codex, or Hermes-style wrappers may use one.

# Claude / Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=

# OpenAI / Codex-style agents
OPENAI_API_KEY=

# Neo4j graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
